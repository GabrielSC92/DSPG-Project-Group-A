# Database Configuration
# Choose 'sqlite' for local development or 'postgresql' for production
DB_TYPE=sqlite

# SQLite Configuration (for local development)
# The database file will be created at this path
DB_PATH=data/qog_local.db

# PostgreSQL Configuration (for production)
# Uncomment and configure these when using PostgreSQL
#DB_HOST=localhost
#DB_PORT=5432
#DB_NAME=qog_production
#DB_USER=qog_user
#DB_PASSWORD=your_secure_password_here

# Alternative: Full DATABASE_URL (takes priority over individual settings)
# Format: postgresql://user:password@host:port/database
#DATABASE_URL=postgresql://user:password@localhost:5432/qog_production

# LLM Configuration (Ollama)
# URL for the Ollama API endpoint
OLLAMA_BASE_URL=http://localhost:11434

# Security Settings
# Session timeout in minutes (optional)
SESSION_TIMEOUT=30

# Maximum login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in minutes
LOCKOUT_DURATION=15

# Application Settings
# Set to 'production' or 'development'
ENVIRONMENT=development

# Debug mode (set to False in production)
DEBUG=False

# IMPORTANT SECURITY NOTES:
# 1. NEVER commit this file with actual secrets to version control
# 2. Copy this file to .env and fill in your actual values
# 3. The .env file is already in .gitignore to prevent accidental commits
# 4. Use strong, randomly generated passwords for production
# 5. Rotate credentials regularly
# 6. Use environment-specific secrets management in production
